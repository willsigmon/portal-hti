    {
      "type": "json-ld",
      "data": {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Do you have a full liquor license?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We have a beer and wine license. For full bar service, you're welcome to bring in a licensed external bar service, which gives you more control over selection and often comes in at a lower cost than a venue-operated bar."
            }
          },
          {
            "@type": "Question",
            "name": "What's included with every booking?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Every booking includes full use of the 5,000 sq ft space, flexible layout configuration, on-site event support, and free on-site parking. Specific inclusions like AV, staging, and bar service vary by package."
            }
          },
          {
            "@type": "Question",
            "name": "What is the minimum booking?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Custom Events start at a 3 hour minimum. Our curated packages range from 5 to 8 hours depending on the event type, with the option to add extra hours at a per-hour rate."
            }
          },
          {
            "@type": "Question",
            "name": "Can we bring outside catering?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, outside caterers are welcome. If you'd prefer we handle it, catering coordination is available as an add-on through our booking process."
            }
          },
          {
            "@type": "Question",
            "name": "Is parking really free?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Free on-site parking is included with every booking. No garages, no meters, no headaches for your guests."
            }
          },
          {
            "@type": "Question",
            "name": "How far in advance should I book?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We recommend booking at least 2-4 weeks in advance, especially for weekend dates. Saturday evenings and holiday weekends tend to go quickly. If you have a specific date in mind, it's always better to lock it in early."
            }
          },
          {
            "@type": "Question",
            "name": "Can I see the space before committing?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. We offer free tours with no commitment required. Visit theportalhq.com/tour.html and we'll show you around and answer any questions in person."
            }
          },
          {
            "@type": "Question",
            "name": "What is your cancellation policy?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We handle cancellations on a case-by-case basis. If your plans change, reach out to us directly at portalheadquarters@gmail.com and we'll work with you to find a solution."
            }
          },
          {
            "@type": "Question",
            "name": "Is the space available for corporate events?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes, we regularly host corporate retreats, conferences, seminars, product launches, and team events. Our Executive Experience package is designed specifically for corporate clients and includes AV, microphones, and full tech support."
            }
          },
          {
            "@type": "Question",
            "name": "What is the maximum capacity?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Up to 200 guests for standing and concert-style events. For seated dinners and formal receptions, we comfortably accommodate up to 100 guests."
            }
          }
        ]
      }
    },
